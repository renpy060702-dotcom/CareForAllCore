import sqlite3
import urllib.request
import csv
import io
import time

CSV_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vQTrsSdJ1LMrRPSJ4MSECO7AN3HJVryQUk-HaYnAXFfoBsxUaaz6us3AXSfJ5Jd05STsJDw5Dp9RJcp/pub?output=csv"
DB_NAME = "vaccine_ssssystem.db"
CHECK_INTERVAL = 30  # seconds


def fetch_csv(url):
    with urllib.request.urlopen(url) as response:
        data = response.read()

    text = data.decode("utf-8-sig")
    reader = csv.DictReader(io.StringIO(text))
    return list(reader)


def create_table(cursor):
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS patients (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            timestamp TEXT UNIQUE,
            name TEXT,
            age INTEGER,
            guardian_name TEXT,
            contact_number TEXT,
            email TEXT,
            vaccine_type TEXT,
            vaccine_schedule TEXT,
            date_of_visit TEXT
        )
    """)


def patient_exists(cursor, timestamp):
    cursor.execute("SELECT 1 FROM patients WHERE timestamp = ?", (timestamp,))
    return cursor.fetchone() is not None


def get_value(row, *possible_keys):
    for key in possible_keys:
        if key in row and row[key] is not None:
            return row[key].strip()
    return ""


def insert_new_data(cursor, rows):
    sql = """
        INSERT INTO patients (
            timestamp,
            name,
            age,
            guardian_name,
            contact_number,
            email,
            vaccine_type,
            vaccine_schedule,
            date_of_visit
        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
    """

    inserted_count = 0

    for row in rows:
        timestamp = get_value(row, "Timestamp")
        name = get_value(row, "Pangalan (Apelyido, Pangalan, M.I.)")
        age = get_value(row, "Edad")
        guardian = get_value(row, "Pangalan ng Magulang o Tagapangalaga")
        contact = get_value(row, "Contact Number (ex. 9649127322)")
        email = get_value(row, "Email Address", "Email address")
        vaccine = get_value(row, "Klase ng Bakuna")
        schedule = get_value(row, "Iskedyul ng mga Bakuna")
        visit = get_value(row, "Petsa ng Pagbisita")

        if not timestamp:
            continue

        if patient_exists(cursor, timestamp):
            continue

        try:
            age = int(age)
        except (TypeError, ValueError):
            age = None

        cursor.execute(sql, (
            timestamp,
            name,
            age,
            guardian,
            contact,
            email,
            vaccine,
            schedule,
            visit
        ))

        inserted_count += 1

    return inserted_count


def check_for_new_patients():
    conn = None
    try:
        rows = fetch_csv(CSV_URL)

        conn = sqlite3.connect(DB_NAME)
        cursor = conn.cursor()

        create_table(cursor)
        inserted = insert_new_data(cursor, rows)

        conn.commit()

        if inserted > 0:
            print(f"New patient(s) added: {inserted}")
        else:
            print("No new patients found.")

    except Exception as e:
        print("Error while checking Google Sheet:", e)

    finally:
        if conn:
            conn.close()


def main():
    print(f"Monitoring Google Sheet for new patients every {CHECK_INTERVAL} seconds...")
    print("-" * 60)

    while True:
        check_for_new_patients()
        time.sleep(CHECK_INTERVAL)


if __name__ == "__main__":
    main()